# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# CookMyBots AI Gateway base URL, for example https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_ENDPOINT=
COOKMYBOTS_AI_KEY=

# Optional CookMyBots X Gateway Proxy for public x.com/twitter.com tweet and thread summaries
COOKMYBOTS_X_ENDPOINT=
COOKMYBOTS_X_KEY=

# Optional runtime controls
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20
